<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progressTint="@color/neon_green"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.adblockplus.libadblockplus.android.webview.AdblockWebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/adBlockerIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:orientation="horizontal"
        android:padding="8dp 16dp"
        android:gravity="center"
        android:visibility="visible">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/green_dot"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/adBlockerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ad_blocker_active"
            android:textColor="@color/neon_green"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/adCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="#e50914"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:padding="2dp 6dp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>